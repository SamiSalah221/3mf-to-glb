{
  "name": "3mf-to-glb",
  "version": "1.1.0",
  "description": "Open-source color customizer for multi-color 3MF files from the Snapmaker U1 / OrcaSlicer / Bambu ecosystem. Recolor zones in a browser, export GLB or 3MF, or convert in Node via the CLI. 100% client-side, MIT-licensed.",
  "author": "Sami Salah",
  "license": "MIT",
  "homepage": "https://samisalah221.github.io/3mf-to-glb/",
  "repository": {
    "type": "git",
    "url": "https://github.com/SamiSalah221/3mf-to-glb.git"
  },
  "bugs": {
    "url": "https://github.com/SamiSalah221/3mf-to-glb/issues"
  },
  "keywords": [
    "3mf",
    "glb",
    "gltf",
    "usdz",
    "3d-printing",
    "three.js",
    "react",
    "paint-color",
    "multi-color",
    "orcaslicer",
    "snapmaker-u1",
    "open-source",
    "khronos-gltf",
    "color-customizer",
    "cli"
  ],
  "type": "module",
  "main": "./dist-lib/lib/index.js",
  "types": "./dist-lib/lib/index.d.ts",
  "bin": {
    "3mf-to-glb": "./dist-lib/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist-lib/lib/index.d.ts",
      "import": "./dist-lib/lib/index.js"
    },
    "./cli": {
      "types": "./dist-lib/cli/index.d.ts",
      "import": "./dist-lib/cli/index.js"
    }
  },
  "files": [
    "dist-lib",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "CODE_OF_CONDUCT.md",
    "CONTRIBUTING.md"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:lib": "tsc -p tsconfig.lib.json && node scripts/postbuild-lib.mjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "cli": "node dist-lib/cli/index.js",
    "test:roundtrip": "node scripts/test-roundtrip.mjs"
  },
  "dependencies": {
    "@gltf-transform/core": "^4.3.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@react-three/postprocessing": "^3.0.4",
    "@tailwindcss/vite": "^4.2.1",
    "@types/three": "^0.183.1",
    "@xmldom/xmldom": "^0.9.10",
    "autoprefixer": "^10.4.27",
    "fast-xml-parser": "^5.5.3",
    "jszip": "^3.10.1",
    "postcss": "^8.5.8",
    "react": "^19.2.0",
    "react-colorful": "^5.6.1",
    "react-dom": "^19.2.0",
    "react-dropzone": "^15.0.0",
    "tailwindcss": "^4.2.1",
    "three": "^0.183.2",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1"
  }
}
